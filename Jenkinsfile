pipeline {
    agent any
    stages {
        stage('Build') {
            steps {
                echo 'Building my first project on an M1 Mac!'
            }
        }
        stage('Test') {
            steps {
                echo 'Testing the code to make sure it works...'
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying the project to the world!'
            }
        }
    }
}
